---
import { type CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const date = entry.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<article class="mb-10">
  <a href={`${base}/blog/${entry.id}/`} class="block no-underline">
    <h3 class="mb-1 text-xl font-semibold text-gray-900 hover:text-[var(--color-accent)]">
      {entry.data.title}
    </h3>
    <p class="text-sm text-gray-500">
      <time datetime={entry.data.date.toISOString()}>{date}</time>
      {entry.data.tags && entry.data.tags.length > 0 && (
        <>
          {' · '}
          {entry.data.tags.map((tag, i) => (
            <span>
              {tag}{i < entry.data.tags.length - 1 ? ', ' : ''}
            </span>
          ))}
        </>
      )}
    </p>
    {entry.data.description && (
      <p class="mt-2 text-gray-700">{entry.data.description}</p>
    )}
  </a>
</article>