---
const { title, description } = Astro.props;
---

<header class="mb-12 flex items-center justify-between">
  <a href="/" class="text-lg font-semibold tracking-tight no-underline">
    {title}
  </a>
  <nav class="flex gap-6 text-sm">
    <a href="/" class="no-underline">Home</a>
    <a href="/blog" class="no-underline">Blog</a>
    <a href="/about" class="no-underline">About</a>
    <a href="/rss.xml" class="no-underline">RSS</a>
  </nav>
</header>
{description && <p class="sr-only">{description}</p>}