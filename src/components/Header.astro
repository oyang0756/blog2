---
const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header class="mb-12 flex items-center justify-between">
  <a href={`${base}/`} class="text-lg font-semibold tracking-tight no-underline">
    {title}
  </a>
  <nav class="flex gap-6 text-sm">
    <a href={`${base}/`} class="no-underline">Home</a>
    <a href={`${base}/blog`} class="no-underline">Blog</a>
    <a href={`${base}/about`} class="no-underline">About</a>
    <a href={`${base}/rss.xml`} class="no-underline">RSS</a>
  </nav>
</header>
{description && <p class="sr-only">{description}</p>}