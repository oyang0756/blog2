---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Blog">
  <section class="mb-12">
    <h1 class="mb-2 text-4xl font-bold tracking-tight">Hi, I'm a blogger.</h1>
    <p class="text-gray-600">
      Welcome to my blog. I write about tech, life, and everything in between.
    </p>
  </section>

  <section>
    <h2 class="mb-6 text-2xl font-semibold">Latest posts</h2>
    <p class="text-gray-600">
      Go to <a href="/blog">/blog</a> to see all posts.
    </p>
  </section>
</BaseLayout>